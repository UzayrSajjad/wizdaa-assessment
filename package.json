{
  "name": "time-off-microservice",
  "version": "1.0.0",
  "description": "Production-grade Time-Off Microservice with HCM integration",
  "author": "Uzair Sajjad",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "babel src --out-dir dist",
    "start": "node dist/main.js",
    "start:dev": "nodemon --exec babel-node src/main.js",
    "start:debug": "nodemon --exec babel-node --inspect src/main.js",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.config.js",
    "mock-hcm": "node mock-hcm/server.js",
    "seed": "babel-node src/seeds/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/schedule": "^4.0.0",
    "typeorm": "^0.3.17",
    "better-sqlite3": "^9.4.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "axios": "^1.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.0",
    "@babel/node": "^7.22.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/plugin-proposal-decorators": "^7.23.0",
    "@babel/plugin-proposal-class-properties": "^7.18.0",
    "@babel/plugin-transform-runtime": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@nestjs/testing": "^10.0.0",
    "jest": "^29.7.0",
    "babel-jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/", "<rootDir>/test/"],
    "testRegex": ".*\\.spec\\.js$",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/main.js",
      "!src/seeds/**"
    ],
    "coverageDirectory": "./coverage",
    "moduleFileExtensions": ["js", "json"]
  }
}
